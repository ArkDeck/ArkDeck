{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arkdeck://contracts/hardware-evidence/3.0.0-draft",
  "title": "ArkDeck real-hardware evidence record (V3 draft, CHG-2026-025)",
  "description": "Records evidence produced on real hardware by a human operator or by an autonomous agent executing under a maintainer-merged standing authorization. Honesty is enforced by maintainer PR review; simulation/fake results must never be recorded here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceId",
    "executor",
    "physicalTargetConfirmation",
    "device",
    "toolchain",
    "transport",
    "provider",
    "stepKinds",
    "acceptanceIds",
    "executedAt",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": "3.0.0" },
    "evidenceId": { "type": "string", "pattern": "^EVD-[A-Z0-9._-]+$" },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["human", "agent"] },
        "id": { "type": "string", "description": "Human operator name (e.g. lvye) or agent identity string." },
        "authorizationRef": { "type": "string", "description": "Reference to the maintainer-merged standing authorization: PR number plus authorization block path/OID. Required when kind=agent and stepKinds include destructive or deviceMutation steps." }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "agent" } }, "required": ["kind"] },
          "then": { "required": ["kind", "id", "authorizationRef"] }
        }
      ]
    },
    "physicalTargetConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmedDeviceIdentity", "confirmedAt", "method"],
      "properties": {
        "confirmedDeviceIdentity": { "type": "string", "description": "Stable device identity (model + serial digest), confirmed before the first dispatch. Raw serial bytes must not enter the repository." },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "method": { "enum": ["humanVisual", "machineReadback"], "description": "humanVisual = operator physically confirmed the target; machineReadback = pre-dispatch device identity readback matched the standing authorization target." }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "serial", "firmware"],
      "properties": {
        "model": { "type": "string" },
        "serial": { "type": "string", "description": "Serial digest (sha256), never raw bytes." },
        "firmware": { "type": "string" },
        "bindingRevision": { "type": "integer", "minimum": 0 }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hdcVersion"],
      "properties": {
        "hdcVersion": { "type": "string" },
        "hdcPath": { "type": "string" },
        "other": { "type": "object" }
      }
    },
    "transport": { "enum": ["usb", "tcp", "uart"] },
    "provider": { "type": "string" },
    "stepKinds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Typed step kinds actually executed. Destructive kinds require the standing authorization of REQ-FLASH-015 (agent) or a human-confirmed plan (human)."
    },
    "acceptanceIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*-[A-Z0-9-]+$" }
    },
    "executedAt": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "note": { "type": "string" }
        }
      }
    },
    "deviations": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
