{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/resource-identity-attestation-1.0.0.json",
  "title": "ArkDeck Protected Canonical Resource Identity Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attestationId",
    "subjectType",
    "claimId",
    "claimSha256",
    "resources",
    "mechanism",
    "issuer",
    "attestationRef"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "attestationId": { "type": "string", "pattern": "^RESOURCEAUTH-[A-Z0-9._-]+$" },
    "subjectType": { "const": "resourceIdentitySet" },
    "claimId": { "type": "string", "minLength": 1 },
    "claimSha256": { "$ref": "#/$defs/sha256" },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    },
    "mechanism": { "const": "protectedClaimService" },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "const": "service" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "attestationRef": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "resource": {
      "oneOf": [
        { "$ref": "#/$defs/hdcServer" },
        { "$ref": "#/$defs/deviceBinding" },
        { "$ref": "#/$defs/hostVolume" }
      ]
    },
    "hdcServer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "resourceUrn", "endpoint", "generation"],
      "properties": {
        "kind": { "const": "hdc-server" },
        "resourceUrn": { "type": "string", "pattern": "^arkdeck-resource:hdc-server:[a-f0-9]{64}$" },
        "endpoint": { "type": "string", "minLength": 1 },
        "generation": { "type": "integer", "minimum": 1 }
      }
    },
    "deviceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "resourceUrn", "deviceIdentity", "bindingRevision"],
      "properties": {
        "kind": { "const": "device-binding" },
        "resourceUrn": { "type": "string", "pattern": "^arkdeck-resource:device-binding:[a-f0-9]{64}$" },
        "deviceIdentity": { "type": "string", "minLength": 1 },
        "bindingRevision": { "type": "integer", "minimum": 1 }
      }
    },
    "hostVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "resourceUrn", "volumeIdentity"],
      "properties": {
        "kind": { "const": "host-volume" },
        "resourceUrn": { "type": "string", "pattern": "^arkdeck-resource:host-volume:[a-f0-9]{64}$" },
        "volumeIdentity": { "type": "string", "minLength": 1 }
      }
    }
  }
}
