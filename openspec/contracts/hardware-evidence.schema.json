{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arkdeck://contracts/hardware-evidence/2.0.0",
  "title": "ArkDeck real-hardware evidence record (V2)",
  "description": "Records evidence produced by a human operator on real hardware. Honesty is enforced by maintainer PR review; simulation/fake results must never be recorded here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceId",
    "operator",
    "physicalTargetConfirmation",
    "device",
    "toolchain",
    "transport",
    "provider",
    "stepKinds",
    "acceptanceIds",
    "executedAt",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0.0" },
    "evidenceId": { "type": "string", "pattern": "^EVD-[A-Z0-9._-]+$" },
    "operator": {
      "type": "string",
      "description": "Human operator who personally executed the steps (e.g. lvye). An agent identity here is invalid."
    },
    "physicalTargetConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmedDeviceIdentity", "confirmedAt"],
      "properties": {
        "confirmedDeviceIdentity": { "type": "string", "description": "Stable device identity (model + serial), confirmed against the physical device before the first dispatch." },
        "confirmedAt": { "type": "string", "format": "date-time" }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "serial", "firmware"],
      "properties": {
        "model": { "type": "string" },
        "serial": { "type": "string" },
        "firmware": { "type": "string" },
        "bindingRevision": { "type": "integer", "minimum": 0 }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hdcVersion"],
      "properties": {
        "hdcVersion": { "type": "string" },
        "hdcPath": { "type": "string" },
        "other": { "type": "object" }
      }
    },
    "transport": { "enum": ["usb", "tcp", "uart"] },
    "provider": { "type": "string" },
    "stepKinds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Typed step kinds actually executed. Destructive kinds require the human-confirmed plan of REQ-FLASH-015."
    },
    "acceptanceIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*-[A-Z0-9-]+$" }
    },
    "executedAt": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "note": { "type": "string" }
        }
      }
    },
    "deviations": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
