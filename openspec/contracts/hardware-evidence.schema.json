{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/hardware-evidence-1.0.0.json",
  "title": "ArkDeck Real Hardware Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceId",
    "status",
    "executionAuthority",
    "taskRunId",
    "labAuthorizationId",
    "executionPlanSha256",
    "runEvidenceId",
    "platform",
    "hostSupportCellId",
    "implementationRevision",
    "device",
    "toolchain",
    "transport",
    "provider",
    "capabilities",
    "stepKinds",
    "acceptanceIds",
    "acceptanceCaseBindings",
    "platformCaseManifestSha256",
    "artifact",
    "observedAt",
    "validUntil",
    "revalidationTriggers",
    "approvalId"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "evidenceId": { "type": "string", "pattern": "^EVD-[A-Z0-9-]+$" },
    "status": { "enum": ["observed", "partial", "verified", "expired", "nonConformant"] },
    "executionAuthority": { "const": "controlledHardwareLab" },
    "taskRunId": { "type": "string", "minLength": 1 },
    "labAuthorizationId": { "type": "string", "pattern": "^LABAUTH-[A-Z0-9._-]+$" },
    "executionPlanSha256": { "$ref": "#/$defs/sha256" },
    "runEvidenceId": { "type": "string", "minLength": 1 },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "hostSupportCellId": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "implementationRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "bindingRevision", "model", "chip", "build", "apiLevel", "buildType", "privilege"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "bindingRevision": { "type": "integer", "minimum": 1 },
        "model": { "type": "string", "minLength": 1 },
        "chip": { "type": "string", "minLength": 1 },
        "build": { "type": "string", "minLength": 1 },
        "apiLevel": { "type": "string", "minLength": 1 },
        "buildType": { "enum": ["user", "root", "engineering", "unknown"] },
        "privilege": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hdcSha256", "clientVersion", "serverVersion", "daemonVersion", "serverEndpoint", "serverGeneration"],
      "properties": {
        "hdcSha256": { "$ref": "#/$defs/sha256" },
        "clientVersion": { "type": "string", "minLength": 1 },
        "serverVersion": { "type": "string", "minLength": 1 },
        "daemonVersion": { "type": "string", "minLength": 1 },
        "serverEndpoint": { "type": "string", "minLength": 1 },
        "serverGeneration": { "type": "integer", "minimum": 1 }
      }
    },
    "transport": { "enum": ["usb", "tcp", "uart"] },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["hdcConnectivity", "uiDump", "trace", "debug", "flash"] }
    },
    "stepKinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "https://arkdeck.dev/schemas/workflow-step-1.0.0.json#/$defs/kind" }
    },
    "acceptanceIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:AC-[A-Z]+-[0-9]{3}-[0-9]{2}|[A-Z]+-M[0-9]+[A-Z0-9-]*-[0-9]{3})$"
      }
    },
    "acceptanceCaseBindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["acceptanceId", "testId", "method", "minimumEvidence", "hardwareCapability", "definitionSha256"],
        "properties": {
          "acceptanceId": {
            "type": "string",
            "pattern": "^(?:AC-[A-Z]+-[0-9]{3}-[0-9]{2}|[A-Z]+-M[0-9]+[A-Z0-9-]*-[0-9]{3})$"
          },
          "testId": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
          "method": { "type": "string", "minLength": 1 },
          "minimumEvidence": { "const": "realHardware" },
          "hardwareCapability": { "enum": ["hdcConnectivity", "uiDump", "trace", "debug", "flash"] },
          "definitionSha256": {
            "$ref": "#/$defs/sha256",
            "description": "SHA-256 of the canonical case contract, including the Core/behavior Scenario block hash or platform expected result."
          }
        }
      }
    },
    "platformCaseManifestSha256": { "$ref": "#/$defs/sha256" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "location"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "location": { "type": "string", "pattern": "^controlledExternal:.+$" }
      }
    },
    "observedAt": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "revalidationTriggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
