{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/platform-conformance-evidence-1.0.0.json",
  "title": "ArkDeck Platform Core Conformance Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceId",
    "status",
    "platform",
    "platformProfile",
    "coreBaseline",
    "conformanceSuite",
    "integrationLock",
    "releaseSubject",
    "acceptanceCount",
    "acceptanceResults",
    "portResults",
    "platformCaseResults",
    "supportMatrix",
    "evidenceManifest",
    "artifact",
    "observedAt",
    "validUntil",
    "revalidationTriggers",
    "approvalId"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "evidenceId": { "type": "string", "pattern": "^PCE-[A-Z0-9._-]+$" },
    "status": { "const": "verified" },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "platformProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "profileSha256", "verificationSha256", "caseManifestSha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^PLATFORM-[A-Z0-9-]+$" },
        "version": { "type": "string", "minLength": 1 },
        "profileSha256": { "$ref": "#/$defs/sha256" },
        "verificationSha256": { "$ref": "#/$defs/sha256" },
        "caseManifestSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "coreBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^CORE-[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "conformanceSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "integrationLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "releaseSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^PRS-[A-Z0-9._-]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "acceptanceCount": { "type": "integer", "minimum": 1 },
    "acceptanceResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["acceptanceId", "testId", "method", "definitionSha256", "minimumEvidence", "result", "cells"],
        "properties": {
          "acceptanceId": { "type": "string", "pattern": "^AC-[A-Z0-9-]+$" },
          "testId": { "type": "string", "pattern": "^TEST-[A-Z0-9-]+$" },
          "method": { "type": "string", "minLength": 1 },
          "definitionSha256": { "$ref": "#/$defs/sha256" },
          "minimumEvidence": { "enum": ["contract", "parserGolden", "platform", "realHardware"] },
          "result": { "const": "passed" },
          "cells": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/resultCell" } }
        }
      }
    },
    "portResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["portId", "definitionSha256", "result", "cells"],
        "properties": {
          "portId": { "type": "string", "pattern": "^PORT-[A-Z0-9-]+$" },
          "definitionSha256": { "$ref": "#/$defs/sha256" },
          "result": { "const": "passed" },
          "cells": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/resultCell" } }
        }
      }
    },
    "platformCaseResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["caseId", "testId", "method", "definitionSha256", "minimumEvidence", "result", "cells"],
        "properties": {
          "caseId": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
          "testId": { "type": "string", "pattern": "^TEST-[A-Z0-9-]+$" },
          "method": { "type": "string", "minLength": 1 },
          "definitionSha256": { "$ref": "#/$defs/sha256" },
          "minimumEvidence": { "enum": ["platform", "manualReview", "realHardware"] },
          "result": { "const": "passed" },
          "cells": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/resultCell" } }
        }
      }
    },
    "supportMatrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cellId", "result", "implementation", "environment", "evidenceSha256"],
        "properties": {
          "cellId": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
          "result": { "const": "passed" },
          "implementation": { "$ref": "#/$defs/implementation" },
          "environment": { "$ref": "#/$defs/environment" },
          "evidenceSha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "evidenceManifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidenceId", "sha256", "classification", "location", "approvalId", "coreBaselineSha256", "conformanceSuiteSha256", "integrationLockSha256", "platformProfileSha256", "platformVerificationSha256", "platformCaseManifestSha256", "implementationRevisions", "caseBindings", "bindingPath", "bindingSha256"],
        "properties": {
          "evidenceId": { "type": "string", "pattern": "^PCEV-[A-Z0-9._-]+$" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "classification": { "enum": ["contract", "parserGolden", "platform", "realHardware", "manualReview"] },
          "location": { "type": "string", "pattern": "^controlledExternal:.+$" },
          "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
          "bindingPath": { "type": "string", "pattern": "^openspec/platforms/conformance-evidence/bindings/PCEV-[A-Z0-9._-]+\\.json$" },
          "bindingSha256": { "$ref": "#/$defs/sha256" },
          "coreBaselineSha256": { "$ref": "#/$defs/sha256" },
          "conformanceSuiteSha256": { "$ref": "#/$defs/sha256" },
          "integrationLockSha256": { "$ref": "#/$defs/sha256" },
          "platformProfileSha256": { "$ref": "#/$defs/sha256" },
          "platformVerificationSha256": { "$ref": "#/$defs/sha256" },
          "platformCaseManifestSha256": { "$ref": "#/$defs/sha256" },
          "implementationRevisions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" }
          },
          "caseBindings": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["subjectType", "subjectId", "definitionSha256"],
              "properties": {
                "subjectType": { "enum": ["coreAcceptance", "platformCase", "port", "supportCell"] },
                "subjectId": { "type": "string", "minLength": 1 },
                "definitionSha256": { "$ref": "#/$defs/sha256" }
              }
            }
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "location"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "location": { "type": "string", "pattern": "^controlledExternal:.+$" }
      }
    },
    "observedAt": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "revalidationTriggers": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "implementationRevisionChanged",
          "releaseArtifactChanged",
          "osBuildChanged",
          "architectureChanged",
          "toolchainChanged",
          "platformProfileChanged",
          "platformVerificationChanged",
          "coreBaselineChanged",
          "conformanceSuiteChanged",
          "integrationLockChanged"
        ]
      }
    },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "resultCell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cellId", "evidenceSha256", "fixtureRefs", "hardwareMatrixRefs"],
      "properties": {
        "cellId": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "evidenceSha256": { "$ref": "#/$defs/sha256" },
        "fixtureRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "hardwareMatrixRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^EVD-[A-Z0-9-]+$" } }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resultRevision", "releaseArtifactSha256", "appVersion", "buildConfiguration"],
      "properties": {
        "resultRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
        "releaseArtifactSha256": { "$ref": "#/$defs/sha256" },
        "appVersion": { "type": "string", "minLength": 1 },
        "buildConfiguration": { "type": "string", "minLength": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["osName", "osVersion", "osBuild", "architecture", "toolchainId", "toolchainVersion", "packageFormat"],
      "properties": {
        "osName": { "enum": ["macos", "windows", "linux"] },
        "osVersion": { "type": "string", "minLength": 1 },
        "osBuild": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "toolchainId": { "type": "string", "minLength": 1 },
        "toolchainVersion": { "type": "string", "minLength": 1 },
        "packageFormat": { "type": "string", "minLength": 1 }
      }
    }
  }
}
