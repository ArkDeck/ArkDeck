{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/approval-1.0.0.json",
  "title": "ArkDeck Human Approval Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "approvalId",
    "subjectType",
    "subjectId",
    "subjectRevision",
    "subjectSha256",
    "baseRevision",
    "decision",
    "approver",
    "approvedAt",
    "mechanism",
    "approvalRef"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
    "subjectType": { "enum": ["change", "changeVerification", "taskPacket", "taskRun", "taskSupersession", "labExecutionAuthorization", "baseline", "integrationLock", "platformLock", "platformReleaseSubject", "platformConformance", "conformanceSuite", "trustPolicy", "evidence", "hardwareEvidence", "archiveSourceVerification", "archive"] },
    "subjectId": { "type": "string", "minLength": 1 },
    "subjectRevision": { "type": "integer", "minimum": 1 },
    "subjectSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "baseRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "decision": { "enum": ["approved", "rejected"] },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "const": "human" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "approvedAt": { "type": "string", "format": "date-time" },
    "mechanism": {
      "enum": ["protectedGitReview", "detachedSignature", "externalApprovalSystem"]
    },
    "approvalRef": { "type": "string", "minLength": 1 },
    "signature": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mechanism": { "const": "detachedSignature" } },
        "required": ["mechanism"]
      },
      "then": {
        "properties": { "signature": { "type": "string", "minLength": 1 } },
        "required": ["signature"]
      }
    }
  ]
}
