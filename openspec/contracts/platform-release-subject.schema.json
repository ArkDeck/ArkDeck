{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/platform-release-subject-1.0.0.json",
  "title": "ArkDeck Protected Platform Release Subject",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseId",
    "platform",
    "platformProfile",
    "coreBaseline",
    "conformanceSuiteSha256",
    "integrationLockSha256",
    "includedCapabilities",
    "supportMatrix",
    "createdAt",
    "approvalId"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "releaseId": { "type": "string", "pattern": "^PRS-[A-Z0-9._-]+$" },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "platformProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "profileSha256", "verificationSha256", "caseManifestSha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^PLATFORM-[A-Z0-9-]+$" },
        "version": { "type": "string", "minLength": 1 },
        "profileSha256": { "$ref": "#/$defs/sha256" },
        "verificationSha256": { "$ref": "#/$defs/sha256" },
        "caseManifestSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "coreBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^CORE-[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "conformanceSuiteSha256": { "$ref": "#/$defs/sha256" },
    "integrationLockSha256": { "$ref": "#/$defs/sha256" },
    "includedCapabilities": {
      "description": "Exact staged-release capability scope. Must contain every capability the capability registry marks release: required, be dependency-closed over requires, and match a capability directory under openspec/specs for every entry. A verified PCE must cover exactly the acceptance IDs of these capabilities.",
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" }
    },
    "supportMatrix": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/supportCell" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "supportCell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cellId", "implementation", "environment"],
      "properties": {
        "cellId": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "implementation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resultRevision", "releaseArtifactSha256", "appVersion", "buildConfiguration"],
          "properties": {
            "resultRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
            "releaseArtifactSha256": { "$ref": "#/$defs/sha256" },
            "appVersion": { "type": "string", "minLength": 1 },
            "buildConfiguration": { "type": "string", "minLength": 1 }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["osName", "osVersion", "osBuild", "architecture", "toolchainId", "toolchainVersion", "packageFormat"],
          "properties": {
            "osName": { "enum": ["macos", "windows", "linux"] },
            "osVersion": { "type": "string", "minLength": 1 },
            "osBuild": { "type": "string", "minLength": 1 },
            "architecture": { "type": "string", "minLength": 1 },
            "toolchainId": { "type": "string", "minLength": 1 },
            "toolchainVersion": { "type": "string", "minLength": 1 },
            "packageFormat": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
