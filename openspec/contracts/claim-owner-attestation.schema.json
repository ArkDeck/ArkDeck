{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/claim-owner-attestation-1.0.0.json",
  "title": "ArkDeck Protected Claim Owner Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attestationId",
    "subjectType",
    "claimId",
    "claimSha256",
    "taskId",
    "attempt",
    "claimantKind",
    "claimedBy",
    "claimedAt",
    "leaseExpiresAt",
    "mechanism",
    "issuer",
    "attestationRef"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "attestationId": { "type": "string", "pattern": "^CLAIMAUTH-[A-Z0-9._-]+$" },
    "subjectType": { "const": "taskClaim" },
    "claimId": { "type": "string", "minLength": 1 },
    "claimSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "claimantKind": { "enum": ["agent", "humanOperator", "automationService"] },
    "claimedBy": { "type": "string", "minLength": 1 },
    "claimedAt": { "type": "string", "format": "date-time" },
    "leaseExpiresAt": { "type": "string", "format": "date-time" },
    "mechanism": { "const": "protectedClaimService" },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "const": "service" },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "attestationRef": { "type": "string", "minLength": 1 }
  }
}
