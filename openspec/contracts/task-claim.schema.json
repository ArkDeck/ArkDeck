{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/task-claim-1.0.0.json",
  "title": "ArkDeck Atomic Task Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "claimId",
    "taskId",
    "taskRevision",
    "changeId",
    "changeRevision",
    "approvalId",
    "taskPacketSha256",
    "coreBaseline",
    "coreBaselineSha256",
    "platformProfile",
    "integrationProfiles",
    "conformanceSuite",
    "platform",
    "baseRevision",
    "attempt",
    "claimantKind",
    "claimedBy",
    "claimedAt",
    "leaseExpiresAt",
    "supersededRunId",
    "taskSupersessionApprovalId",
    "status",
    "exclusiveResources"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "claimId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
    "taskRevision": { "type": "integer", "minimum": 1 },
    "changeId": { "type": "string", "pattern": "^CHG-[0-9]{4}-[0-9]{3}.*$" },
    "changeRevision": { "type": "integer", "minimum": 1 },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
    "taskPacketSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "coreBaseline": { "type": "string", "pattern": "^CORE-[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "coreBaselineSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "platformProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "integrationProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "sha256"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "conformanceSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "baseRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "claimantKind": { "enum": ["agent", "humanOperator", "automationService"] },
    "claimedBy": { "type": "string", "minLength": 1 },
    "claimedAt": { "type": "string", "format": "date-time" },
    "leaseExpiresAt": { "type": "string", "format": "date-time" },
    "supersededRunId": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "taskSupersessionApprovalId": {
      "oneOf": [
        { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
        { "type": "null" }
      ]
    },
    "status": { "const": "claimed" },
    "exclusiveResources": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^arkdeck-resource:(?:hdc-server|device-binding|host-volume|vm-snapshot|fixture|toolchain|host-lock|workspace):(?:[A-Za-z0-9._~-]|%[0-9A-F]{2})+$"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "supersededRunId": { "type": "string" } },
        "required": ["supersededRunId"]
      },
      "then": {
        "properties": { "taskSupersessionApprovalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" } }
      },
      "else": {
        "properties": { "taskSupersessionApprovalId": { "type": "null" } }
      }
    }
  ]
}
