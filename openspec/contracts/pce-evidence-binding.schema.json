{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/pce-evidence-binding-1.0.0.json",
  "title": "ArkDeck Platform Conformance Evidence Binding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bindingId",
    "artifactSha256",
    "classification",
    "location",
    "coreBaselineSha256",
    "conformanceSuiteSha256",
    "integrationLockSha256",
    "platformProfileSha256",
    "platformVerificationSha256",
    "platformCaseManifestSha256",
    "implementationRevisions",
    "caseBindings",
    "approvalId"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "bindingId": { "type": "string", "pattern": "^PCEV-[A-Z0-9._-]+$" },
    "artifactSha256": { "$ref": "#/$defs/sha256" },
    "classification": { "enum": ["contract", "parserGolden", "platform", "realHardware", "manualReview"] },
    "location": { "type": "string", "pattern": "^controlledExternal:.+$" },
    "coreBaselineSha256": { "$ref": "#/$defs/sha256" },
    "conformanceSuiteSha256": { "$ref": "#/$defs/sha256" },
    "integrationLockSha256": { "$ref": "#/$defs/sha256" },
    "platformProfileSha256": { "$ref": "#/$defs/sha256" },
    "platformVerificationSha256": { "$ref": "#/$defs/sha256" },
    "platformCaseManifestSha256": { "$ref": "#/$defs/sha256" },
    "implementationRevisions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/gitOid" }
    },
    "caseBindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/caseBinding" }
    },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gitOid": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "caseBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectType", "subjectId", "definitionSha256"],
      "properties": {
        "subjectType": { "enum": ["coreAcceptance", "platformCase", "port", "supportCell"] },
        "subjectId": { "type": "string", "minLength": 1 },
        "definitionSha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
