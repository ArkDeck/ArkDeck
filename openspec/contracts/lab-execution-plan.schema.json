{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/lab-execution-plan-1.0.0.json",
  "title": "ArkDeck Immutable Hardware Lab Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "serialization", "planId", "taskId", "platform", "target", "steps"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "serialization": { "const": "arkdeck-plan-json-bytes-v1" },
    "planId": { "type": "string", "pattern": "^LABPLAN-[A-Z0-9._-]+$" },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "target": { "$ref": "#/$defs/target" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://arkdeck.dev/schemas/workflow-step-1.0.0.json#/$defs/workflowStep" }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deviceIdentity",
        "bindingRevision",
        "firmware",
        "transport",
        "hdcExecutableSha256",
        "hdcClientVersion",
        "hdcServerVersion",
        "hdcDaemonVersion",
        "hdcServerEndpoint",
        "hdcServerGeneration",
        "hostVolumeIdentity",
        "resourceUrns",
        "providerId",
        "providerVersion"
      ],
      "properties": {
        "deviceIdentity": { "type": "string", "minLength": 1 },
        "bindingRevision": { "type": "integer", "minimum": 1 },
        "firmware": { "type": "string", "minLength": 1 },
        "transport": { "enum": ["usb", "tcp", "uart"] },
        "hdcExecutableSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "hdcClientVersion": { "type": "string", "minLength": 1 },
        "hdcServerVersion": { "type": "string", "minLength": 1 },
        "hdcDaemonVersion": { "type": "string", "minLength": 1 },
        "hdcServerEndpoint": { "type": "string", "minLength": 1 },
        "hdcServerGeneration": { "type": "integer", "minimum": 1 },
        "hostVolumeIdentity": { "type": ["string", "null"], "minLength": 1 },
        "resourceUrns": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hdcServer", "deviceBinding", "hostVolume"],
          "properties": {
            "hdcServer": {
              "oneOf": [
                { "type": "string", "pattern": "^arkdeck-resource:hdc-server:[a-f0-9]{64}$" },
                { "type": "null" }
              ]
            },
            "deviceBinding": {
              "oneOf": [
                { "type": "string", "pattern": "^arkdeck-resource:device-binding:[a-f0-9]{64}$" },
                { "type": "null" }
              ]
            },
            "hostVolume": {
              "oneOf": [
                { "type": "string", "pattern": "^arkdeck-resource:host-volume:[a-f0-9]{64}$" },
                { "type": "null" }
              ]
            }
          }
        },
        "providerId": { "type": "string", "minLength": 1 },
        "providerVersion": { "type": "string", "minLength": 1 }
      }
    }
  }
}
