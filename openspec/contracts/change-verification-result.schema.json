{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/change-verification-result-1.0.0.json",
  "title": "ArkDeck Immutable Change Verification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "verificationId",
    "changeId",
    "changeRevision",
    "status",
    "changeLockSha256",
    "verificationPlanSha256",
    "resultRevision",
    "taskRuns",
    "acceptanceResults",
    "verifiedAt",
    "approvalId"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "verificationId": { "type": "string", "pattern": "^CHGVERIFY-[A-Z0-9._-]+$" },
    "changeId": { "type": "string", "pattern": "^CHG-[0-9]{4}-[0-9]{3}(?:-[A-Za-z0-9-]+)?$" },
    "changeRevision": { "type": "integer", "minimum": 1 },
    "status": { "const": "passed" },
    "changeLockSha256": { "$ref": "#/$defs/sha256" },
    "verificationPlanSha256": { "$ref": "#/$defs/sha256" },
    "resultRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "taskRuns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "runId", "runSha256", "resultRevision"],
        "properties": {
          "taskId": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
          "runId": { "type": "string", "minLength": 1 },
          "runSha256": { "$ref": "#/$defs/sha256" },
          "resultRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" }
        }
      }
    },
    "acceptanceResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["acceptanceId", "testId", "runId", "result"],
        "properties": {
          "acceptanceId": { "type": "string", "pattern": "^(?:AC-[A-Z]+-[0-9]{3}-[0-9]{2}|[A-Z]+-M[0-9]+[A-Z]*-[A-Z0-9]+(?:-[A-Z0-9]+)*-[0-9]{3})$" },
          "testId": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
          "runId": { "type": "string", "minLength": 1 },
          "result": { "const": "passed" }
        }
      }
    },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
