{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkdeck.dev/schemas/task-packet-1.0.0.json",
  "title": "ArkDeck Immutable Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "revision",
    "status",
    "changeId",
    "changeRevision",
    "approvalId",
    "coreBaseline",
    "platformProfile",
    "integrationProfiles",
    "conformanceSuite",
    "baseRevision",
    "platform",
    "objective",
    "requirementRefs",
    "acceptanceRefs",
    "dependsOn",
    "allowedPaths",
    "forbiddenPaths",
    "exclusiveResources",
    "risk",
    "executionEnvironment",
    "runtimeCapabilities",
    "hardwareRequirement",
    "deliverables",
    "verification",
    "stopConditions"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
    "revision": { "const": 1 },
    "status": { "enum": ["draft", "ready"] },
    "changeId": { "type": "string", "pattern": "^CHG-[0-9]{4}-[0-9]{3}(?:-[A-Za-z0-9-]+)?$" },
    "changeRevision": { "const": 1 },
    "approvalId": {
      "oneOf": [
        { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
        { "type": "null" }
      ]
    },
    "coreBaseline": { "$ref": "#/$defs/versionedPin" },
    "platformProfile": { "$ref": "#/$defs/versionedPin" },
    "integrationProfiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/versionedPin" }
    },
    "conformanceSuite": { "$ref": "#/$defs/hashPin" },
    "baseRevision": { "type": ["string", "null"], "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
    "platform": { "enum": ["macos", "windows", "linux"] },
    "objective": { "type": "string", "minLength": 1 },
    "requirementRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:REQ|POL|PORT|PLATFORM)-[A-Z0-9@._:-]+$"
      }
    },
    "acceptanceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/acceptanceId" }
    },
    "dependsOn": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" }
    },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repositoryPathPattern" }
    },
    "forbiddenPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repositoryPathPattern" }
    },
    "exclusiveResources": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/resourceUrn" }
    },
    "risk": { "enum": ["low", "medium", "high", "destructive"] },
    "executionEnvironment": { "enum": ["standardAgent", "controlledHardwareLab"] },
    "runtimeCapabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "repositoryProcess",
          "externalToolExecution",
          "deviceNetworkAccess",
          "internetAccess",
          "realDeviceRead",
          "realDeviceMutation",
          "destructiveDeviceMutation",
          "hostPackageInstall",
          "hostPrivilegeElevation",
          "externalFilesystemWrite"
        ]
      }
    },
    "hardwareRequirement": { "enum": ["none", "optional", "required"] },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["acceptanceId", "testId", "method", "expectedEvidence", "minimumEvidence", "fixtureRefs"],
        "properties": {
          "acceptanceId": { "$ref": "#/$defs/acceptanceId" },
          "testId": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
          "method": { "type": "string", "minLength": 1 },
          "expectedEvidence": { "type": "string", "minLength": 1 },
          "minimumEvidence": {
            "enum": ["contract", "parserGolden", "platform", "realHardware", "manualReview"]
          },
          "fixtureRefs": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "stopConditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "approvalId": { "type": "string", "pattern": "^APR-[A-Z0-9._-]+$" },
          "baseRevision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" },
          "coreBaseline": { "$ref": "#/$defs/resolvedVersionedPin" },
          "platformProfile": { "$ref": "#/$defs/resolvedVersionedPin" },
          "integrationProfiles": {
            "items": { "$ref": "#/$defs/resolvedVersionedPin" }
          },
          "conformanceSuite": { "$ref": "#/$defs/resolvedHashPin" },
          "exclusiveResources": {
            "items": {
              "oneOf": [
                { "type": "string", "pattern": "^arkdeck-resource:(?:hdc-server|device-binding|host-volume):[a-f0-9]{64}$" },
                { "type": "string", "pattern": "^arkdeck-resource:(?:vm-snapshot|fixture|toolchain|host-lock|workspace):(?:[A-Za-z0-9._~-]|%[0-9A-F]{2})+$" }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256OrNull": {
      "oneOf": [
        { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        { "type": "null" }
      ]
    },
    "versionedPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256OrNull" }
      }
    },
    "resolvedVersionedPin": {
      "allOf": [
        { "$ref": "#/$defs/versionedPin" },
        { "properties": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } }
      ]
    },
    "hashPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256OrNull" }
      }
    },
    "resolvedHashPin": {
      "allOf": [
        { "$ref": "#/$defs/hashPin" },
        { "properties": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } }
      ]
    },
    "acceptanceId": {
      "type": "string",
      "pattern": "^(?:AC-[A-Z]+-[0-9]{3}-[0-9]{2}|[A-Z]+-M[0-9]+[A-Z]*-[A-Z0-9]+(?:-[A-Z0-9]+)*-[0-9]{3})$"
    },
    "repositoryPathPattern": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$"
    },
    "resourceUrn": {
      "type": "string",
      "pattern": "^arkdeck-resource:(?:hdc-server|device-binding|host-volume|vm-snapshot|fixture|toolchain|host-lock|workspace):(?:[A-Za-z0-9._~-]|%[0-9A-F]{2})+$"
    }
  }
}
